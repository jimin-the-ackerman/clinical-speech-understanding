# Copy to .env and fill in the keys you have — `cp .env.example .env`.
# Runs load it explicitly, e.g. `uv run --env-file .env stt-eval transcribe ...`.
# A missing key just skips the model or step that needs it (with a warning),
# so fill in only what you plan to run. .env is gitignored — never commit it.

# ── Cloud STT APIs — one key per transcriber; omit a key to skip that model ──
# gpt-4o-transcribe
OPENAI_API_KEY=
# soniox-stt-async-v5
SONIOX_API_KEY=
# deepgram-nova-3-medical  (not run in the current round — leave blank)
DEEPGRAM_API_KEY=
# assemblyai-universal-3-5-pro  (not run in the current round — leave blank)
ASSEMBLYAI_API_KEY=

# ── Hugging Face — dataset downloads + local gated models ──
# Needed by `stt-eval prepare` (MedDialog-Audio) and the `medgemma` entity
# method (gated model — accept its license on Hugging Face first).
HF_TOKEN=

# ── Entity metric: general-LLM foil (optional) ──
# Only for `stt-eval entity-build --method openrouter`.
OPENROUTER_API_KEY=
